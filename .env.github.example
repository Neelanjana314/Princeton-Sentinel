# ============================================================
# GitHub Environment: staging
# ============================================================
# This file documents the GitHub Environment variables/secrets expected by
# .github/workflows/deploy-staging.yml.
#
# Staging runtime configuration no longer lives in GitHub variables/secrets.
# Put runtime values such as DATABASE_URL, ENTRA_CLIENT_SECRET, Dataverse
# settings, worker tokens, and tuning values in Azure Key Vault instead.
# Key Vault secret names match runtime env names with underscores converted
# to hyphens, for example DATABASE_URL -> DATABASE-URL.


# ============================================================
# REQUIRED: GitHub Secrets
# ============================================================

# Azure OIDC for GitHub Actions deployment login
AZURE_CLIENT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=


# ============================================================
# REQUIRED: GitHub Variables
# ============================================================

# Shared Azure target selection
AZ_RESOURCE_GROUP=RG-Princeton-Sentinel
AZ_ACR_NAME=princetonsentinelacr
AZ_WEB_APP_NAME=princeton-sentinel-webapp-stg
AZ_WORKER_APP_NAME=princeton-sentinel-worker-stg

# Azure Key Vault containing staging runtime config
AZ_KEY_VAULT_URL=https://<vault-name>.vault.azure.net

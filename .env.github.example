# ============================================================
# GitHub Environment: staging
# ============================================================
# This file documents the GitHub Environment variables/secrets expected by
# .github/workflows/deploy-staging.yml. Keep real secrets in GitHub Secrets,
# not in this example file.


# ============================================================
# REQUIRED: GitHub Secrets
# ============================================================

# Azure OIDC
AZURE_CLIENT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=

# Shared staging runtime secrets
STG_DATABASE_URL=
STG_ENTRA_CLIENT_SECRET=
STG_WORKER_HEARTBEAT_TOKEN=
STG_WORKER_INTERNAL_API_TOKEN=

# Application Insights
STG_APPINSIGHTS_API_KEY=


# ============================================================
# REQUIRED: GitHub Variables
# ============================================================

# Shared Azure target selection
AZ_RESOURCE_GROUP=RG-Princeton-Sentinel
AZ_ACR_NAME=princetonsentinelacr
AZ_WEB_APP_NAME=princeton-sentinel-webapp-stg
AZ_WORKER_APP_NAME=princeton-sentinel-worker-stg

# Web staging runtime config
STG_ENTRA_TENANT_ID=
STG_ENTRA_CLIENT_ID=
STG_ADMIN_GROUP_ID=
STG_USER_GROUP_ID=
STG_DASHBOARD_DORMANT_LOOKBACK_DAYS=90
STG_INTERNAL_EMAIL_DOMAINS=

# Dataverse / Power Platform
STG_DATAVERSE_BASE_URL=
STG_DATAVERSE_TABLE_URL=
STG_DATAVERSE_COLUMN_PREFIX=cr6c3
STG_DATAVERSE_AGENT_SECURITY_GROUP_MAPPING_TABLE_URL=
STG_POWER_PLATFORM_ENVIRONMENT_ID=

# Worker staging runtime config
STG_APPINSIGHTS_APP_ID=
STG_DB_CONNECT_TIMEOUT_SECONDS=10
STG_SCHEDULER_POLL_SECONDS=30
STG_GRAPH_BASE=https://graph.microsoft.com/v1.0
STG_GRAPH_CONNECT_TIMEOUT=10
STG_GRAPH_MAX_CONCURRENCY=4
STG_GRAPH_MAX_RETRIES=5
STG_GRAPH_PAGE_SIZE=200
STG_GRAPH_PERMISSIONS_BATCH_SIZE=100
STG_GRAPH_PERMISSIONS_STALE_AFTER_HOURS=36
STG_GRAPH_READ_TIMEOUT=60
STG_FLUSH_EVERY=1000

# Licensing
STG_LICENSE_PUBLIC_KEY_PATH=/mnt/secrets/license-public.pem
STG_LICENSE_CACHE_TTL_SECONDS=43200

# Current staging URL overrides
STG_WORKER_API_URL=
STG_WORKER_HEARTBEAT_URL=


# ============================================================
# OPTIONAL: GitHub vars/secrets with workflow fallback behavior
# ============================================================

# If unset, workflow derives the auth URL from the web Container App FQDN.
STG_NEXTAUTH_URL=

# If unset, workflow derives the worker heartbeat URL from the web Container App FQDN.
# STG_WORKER_HEARTBEAT_URL=
